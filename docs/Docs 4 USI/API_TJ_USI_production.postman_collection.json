    {
      "name": "02 Staging",
      "item": [
        {
          "name": "Crear staging valido",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const seed = Date.now().toString();",
                  "const alnum = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ';",
                  "const alnumChar = alnum[Number(seed.slice(-2)) % 36];",
                  "const lastDigit = seed.slice(-1);",
                  "pm.environment.set('externalRequestId', 'UI-POSTMAN-' + seed);",
                  "pm.environment.set('stagingCurpGenerated', 'AEIA000101MSPLRN' + alnumChar + lastDigit);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 202', function () { pm.response.to.have.status(202); });",
                  "const data = pm.response.json();",
                  "pm.test('created true', function () { pm.expect(data.created).to.eql(true); });",
                  "pm.environment.set('stagingId', data.staging_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{integrationToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_request_id\": \"{{externalRequestId}}\",\n  \"beneficiario\": {\n    \"curp\": \"{{stagingCurpGenerated}}\",\n    \"nombre\": \"JULIETA\",\n    \"apellido_paterno\": \"MORALES\",\n    \"apellido_materno\": \"CANO\",\n    \"fecha_nacimiento\": \"2005-05-21\",\n    \"sexo\": \"M\",\n    \"discapacidad\": false,\n    \"id_ine\": \"INE123456\",\n    \"telefono\": \"4441234567\",\n    \"domicilio\": {\n      \"calle\": \"AV REVOLUCION\",\n      \"numero_ext\": \"321B\",\n      \"numero_int\": null,\n      \"colonia\": \"ZONA CENTRO\",\n      \"municipio_id\": 1,\n      \"codigo_postal\": \"22000\",\n      \"seccional\": \"001\"\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/beneficiarios-staging",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
