# Runtime
NODE_ENV=production
PORT=8080
FRONTEND_ORIGIN=https://tu-frontend.example.com
ADMIN_FRONTEND_ORIGIN=https://tu-admin.example.com

# Database
# En Railway MySQL puedes usar directamente la variable nativa:
# DB_URI=${{MySQL.MYSQL_URL}}
# O dejar que la app lea MYSQL_URL / MYSQLHOST / MYSQLPORT / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE.
DB_URI=mysql://usuario:password@host:3306/tarjeta_joven
DB_CONNECTION_LIMIT=10

# Variables separadas (opcionales)
# DB_HOST=containers-us-west-123.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=tu_password
# DB_NAME=tarjeta_joven

# TLS opcional para proveedores externos como TiDB / Aiven
# TIDB_ENABLE_SSL=true
# TIDB_CA_PATH=/app/certs/tidb-ca.pem
# TIDB_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# TIDB_CA_BASE64=
# DB_SSL_REJECT_UNAUTHORIZED=true

# Auth local
JWT_SECRET=reemplaza-por-un-secreto-largo-y-aleatorio
ADMIN_JWT_SECRET=reemplaza-por-un-secreto-distinto-para-admin
JWT_EXPIRATION=15m
ADMIN_JWT_EXPIRATION=8h
USER_TOKEN_ISSUER=api_tj:user
USER_TOKEN_AUDIENCE=api_tj:public
ADMIN_TOKEN_ISSUER=api_tj:admin
ADMIN_TOKEN_AUDIENCE=api_tj:admin
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=tj_refresh_token
# AUTH_COOKIE_SECURE=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
# PASSWORD_RESET_URL_BASE=https://tu-frontend.example.com/reset-password
# PASSWORD_RESET_DEBUG=false

# Seguridad de datos
# Define estos valores antes del primer deploy productivo y no los cambies
# despues de empezar a guardar datos, o romperas hash/descifrado historico.
CURP_HASH_SECRET=reemplaza-por-un-secreto-largo-y-aleatorio
FIELD_ENCRYPTION_KEY=reemplaza-por-una-llave-larga-o-32-bytes-base64-o-hex
FIELD_ENCRYPTION_ALGORITHM=aes-256-gcm

# Integraciones
INTEGRATION_JWT_AUDIENCE=api_tj
INTEGRATION_RATE_WINDOW_MS=900000
INTEGRATION_RATE_MAX=300
SYS_IPJ_PUSH_URL=
SYS_IPJ_PUSH_TIMEOUT_MS=8000
# Bootstrap automatico de clientes de integracion al arrancar la API.
# Usa PEM normal o con saltos escapados como \n.
SYS_IPJ_JWT_PUBLIC_KEY=
SYS_IPJ_JWT_KID=sys_ipj-current
SYS_IPJ_ALLOWED_SCOPES=["cardholders.sync"]
SYS_IPJ_IP_ALLOWLIST=[]
INFORMATICA_JWT_PUBLIC_KEY=
INFORMATICA_JWT_KID=unidad_informatica-current
INFORMATICA_ALLOWED_SCOPES=["cardholders.lookup","beneficiarios.staging.create"]
INFORMATICA_IP_ALLOWLIST=[]

# Operacion
STAGING_TTL_DAYS=30
EXPOSE_PII=false

# Importante para Railway / produccion
SEED_ON_START=false
ALLOW_PROD_SEED=false

# Bootstrap operativo sin shell en Railway
# Activa solo para el deploy donde quieras crear el primer admin o beneficiarios de prueba.
BOOTSTRAP_USERS_ON_DEPLOY=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NOMBRE=
BOOTSTRAP_ADMIN_APELLIDOS=
BOOTSTRAP_ADMIN_TELEFONO=
BOOTSTRAP_ADMIN_MUNICIPIO_ID=
BOOTSTRAP_ADMIN_ROLE=admin
BOOTSTRAP_ADMIN_STATUS=active
# JSON array. Ejemplo:
# BOOTSTRAP_BENEFICIARIES_JSON=[{"curp":"ABCD010101HSPXXX01","tarjeta_numero":"TJ-PROD-0005","email":"beneficiario5@example.com","password":"BenefProd#2026E","nombre":"Prueba","apellidos":"Cinco","municipio_id":1}]
BOOTSTRAP_BENEFICIARIES_JSON=
